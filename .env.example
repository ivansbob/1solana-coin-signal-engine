APP_ENV=dev
LOG_LEVEL=INFO

DATA_DIR=./data
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed
SIGNALS_DIR=./data/signals
TRADES_DIR=./data/trades
POSITIONS_DIR=./data/positions
SMOKE_DIR=./data/smoke

OPENCLAW_ENABLED=true
OPENCLAW_LOCAL_ONLY=true
OPENCLAW_PROFILE_PATH=~/.openclaw/x-profile
OPENCLAW_SNAPSHOTS_DIR=./data/smoke

X_VALIDATION_ENABLED=true
X_DEGRADED_MODE_ALLOWED=true
LOCAL_OPENCLAW_ONLY=true

OPENCLAW_BROWSER_PROFILE=openclaw
OPENCLAW_BROWSER_TARGET=host
OPENCLAW_X_QUERY_MAX=4
OPENCLAW_X_TOKEN_MAX_CONCURRENCY=2
OPENCLAW_X_CACHE_TTL_SEC=600
OPENCLAW_X_PAGE_TIMEOUT_MS=12000
OPENCLAW_X_NAV_TIMEOUT_MS=15000
OPENCLAW_X_MAX_SCROLLS=2
OPENCLAW_X_MAX_POSTS_PER_QUERY=15
OPENCLAW_X_DEGRADED_SCORE=45
OPENCLAW_X_FAILOPEN=true
X_VALIDATION_CONTRACT_VERSION=x_validation_v1

X_SEARCH_TEST_QUERY=solana memecoin
X_MAX_TOKENS_PER_CYCLE=5
X_MAX_CONCURRENCY=2
X_CACHE_TTL_SEC=600

DEX_CACHE_TTL_SEC=60
HELIUS_CACHE_TTL_SEC=120
GLOBAL_RATE_LIMIT_ENABLED=true

SMART_WALLETS_PATH=./data/processed/smart_wallets.json

ONCHAIN_ENRICHMENT_ENABLED=true
ONCHAIN_ENRICHMENT_MAX_TOKENS=5
ONCHAIN_ENRICHMENT_FAILOPEN=true
HELIUS_API_KEY=
HELIUS_TX_ADDR_LIMIT=40
HELIUS_TX_SIG_BATCH=25
HELIUS_ENRICH_CACHE_TTL_SEC=300
SOLANA_RPC_URL=
SOLANA_RPC_COMMITMENT=confirmed
SMART_WALLET_SEED_PATH=data/seeds/smart_wallets.json
SMART_WALLET_HIT_WINDOW_SEC=300
PROGRAM_ID_MAP_PATH=config/program_ids.json
ALLOW_LAUNCH_PATH_HEURISTICS_ONLY=true

RUG_ENGINE_ENABLED=true
RUG_ENGINE_FAILCLOSED=true
RUG_ENGINE_PARTIAL_ALLOWED=true

RUG_IGNORE_THRESHOLD=0.55
RUG_WATCH_THRESHOLD=0.35

RUG_TOP1_HOLDER_HARD_MAX=0.20
RUG_TOP20_HOLDER_HARD_MAX=0.65
RUG_DEV_SELL_PRESSURE_WARN=0.10
RUG_DEV_SELL_PRESSURE_HARD=0.25

RUG_REQUIRE_DISTINCT_BURN_AND_LOCK=true
RUG_LP_BURN_OWNER_ALLOWLIST=11111111111111111111111111111111
RUG_LP_LOCK_PROGRAM_ALLOWLIST_PATH=config/lock_programs.json

RUG_EVENT_CACHE_TTL_SEC=300

# PR-6 unified scoring
UNIFIED_SCORING_ENABLED=true
UNIFIED_SCORING_FAILOPEN=false
UNIFIED_SCORING_REQUIRE_X=false
UNIFIED_SCORE_ENTRY_THRESHOLD=82
UNIFIED_SCORE_WATCH_THRESHOLD=68
UNIFIED_SCORE_PARTIAL_REVIEW_BUFFER=1.0
UNIFIED_SCORE_IGNORE_RUG_THRESHOLD=0.55
UNIFIED_SCORE_X_DEGRADED_PENALTY=8
UNIFIED_SCORE_PARTIAL_DATA_PENALTY=5
UNIFIED_SCORE_PARTIAL_EVIDENCE_PENALTY=1.5
UNIFIED_SCORE_EVIDENCE_LOW_CONFIDENCE_THRESHOLD=0.55
UNIFIED_SCORE_LOW_CONFIDENCE_EVIDENCE_PENALTY_MAX=3.0
UNIFIED_SCORE_EVIDENCE_CONFLICT_PENALTY_BONUS=0.75
UNIFIED_SCORE_HEURISTIC_CONFIDENCE_FLOOR=0.50
UNIFIED_SCORE_CONTRACT_VERSION=unified_score_v1
WALLET_WEIGHTING_MODE=shadow
WALLET_WEIGHTING_CAP_TIER1=8.0
WALLET_WEIGHTING_CAP_TIER2=5.0
WALLET_WEIGHTING_CAP_TIER3=3.0
WALLET_WEIGHTING_CAP_WATCH_ONLY=1.0
WALLET_WEIGHTING_SCORE_SUM_MAX=20.0
WALLET_WEIGHTING_TIER_HIT_STRENGTH_MAX=6.0
WALLET_WEIGHTING_EARLY_ENTRY_MAX=2.0
WALLET_WEIGHTING_CONVICTION_MAX=3.0

# PR-7 entry selector
ENTRY_SELECTOR_ENABLED=true
ENTRY_SELECTOR_FAILCLOSED=true

ENTRY_SCALP_SCORE_MIN=82
ENTRY_TREND_SCORE_MIN=86

ENTRY_SCALP_MAX_AGE_SEC=480
ENTRY_SCALP_MAX_HOLD_SEC=120

ENTRY_TREND_MIN_X_SCORE=65
ENTRY_SCALP_MIN_X_SCORE=50

ENTRY_RUG_MAX_SCALP=0.30
ENTRY_RUG_MAX_TREND=0.20

ENTRY_BUY_PRESSURE_MIN_SCALP=0.75
ENTRY_BUY_PRESSURE_MIN_TREND=0.65

ENTRY_FIRST30S_BUY_RATIO_MIN=0.65
ENTRY_BUNDLE_CLUSTER_MIN=0.55

ENTRY_SMART_WALLET_HITS_MIN_TREND=2
ENTRY_HOLDER_GROWTH_MIN_TREND=20

ENTRY_DEGRADED_X_SIZE_MULTIPLIER=0.50
ENTRY_PARTIAL_DATA_SIZE_MULTIPLIER=0.60
ENTRY_MAX_BASE_POSITION_PCT=1.00

ENTRY_CONTRACT_VERSION=entry_selector_v1

# PR-10 post-run analyzer
POST_RUN_ANALYZER_ENABLED=true
POST_RUN_ANALYZER_FAILCLOSED=true

POST_RUN_MIN_TRADES_FOR_CORRELATION=20
POST_RUN_MIN_TRADES_FOR_REGIME_COMPARISON=10
POST_RUN_MIN_SAMPLE_FOR_RECOMMENDATION=15

POST_RUN_INCLUDE_DEGRADED_X_ANALYSIS=true
POST_RUN_INCLUDE_FRICTION_ANALYSIS=true
POST_RUN_INCLUDE_PARTIAL_FILL_ANALYSIS=true

POST_RUN_CORRELATION_METHOD=pearson_spearman
POST_RUN_OUTLIER_CLIP_PCT=0.01
POST_RUN_RECOMMENDATION_CONFIDENCE_MIN=0.55

POST_RUN_CONTRACT_VERSION=post_run_analyzer_v1

# PR-SL-1-lite config suggestion generator
CONFIG_SUGGESTIONS_ENABLED=true
CONFIG_SUGGESTIONS_MIN_SAMPLE=15
CONFIG_SUGGESTIONS_TRAINING_WHEELS_MODE=true
CONFIG_SUGGESTIONS_CONTRACT_VERSION=config_suggestions_v1

# PR-8/PR-9 exit + paper
EXIT_ENGINE_ENABLED=true
EXIT_ENGINE_FAILCLOSED=true
EXIT_SCALP_BUY_PRESSURE_FLOOR=0.60
EXIT_TREND_BUY_PRESSURE_FLOOR=0.50
EXIT_POLL_INTERVAL_SEC=3

PAPER_TRADER_ENABLED=true
PAPER_STARTING_CAPITAL_SOL=0.1
PAPER_MAX_SLIPPAGE_BPS=1200
PAPER_PRIORITY_FEE_SPIKE_MULTIPLIER=1.75
