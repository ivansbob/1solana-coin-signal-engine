{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TotalScore V7 Coverage Engine Constraint Matrix",
  "description": "Formally limits algorithm mappings blocking unmapped properties forcing logical overlaps.",
  "type": "object",
  "properties": {
    "metrics": {
      "type": "object",
      "patternProperties": {
        "^[A-Za-z0-9_]+$": {
          "type": "object",
          "properties": {
            "bucket": {
              "type": "string",
              "enum": [
                "score_contribution",
                "hard_gate",
                "regime_modifier",
                "exit_modifier",
                "sizing_modifier",
                "replay_only",
                "paper_only_realism"
              ]
            },
            "weight": {
              "type": "number",
              "minimum": -10.0,
              "maximum": 10.0
            },
            "stage": {
              "type": "string",
              "enum": [
                "active",
                "research",
                "optional",
                "deferred"
              ]
            }
          },
          "required": ["bucket", "stage"]
        }
      }
    }
  },
  "required": ["metrics"]
}
