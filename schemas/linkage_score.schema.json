{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/linkage_score.schema.json",
  "title": "Creator/Dev/Funder Linkage Score",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "metadata",
    "contract_version",
    "generated_at",
    "token_pair_linkage",
    "linkage_status",
    "linkage_reason_codes",
    "linkage_confidence"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "schema_name": {"type": "string"},
        "schema_version": {"type": "string"},
        "producer": {"type": "string"}
      }
    },
    "contract_version": {"type": "string"},
    "generated_at": {"type": "string"},
    "token_pair_linkage": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "token_address": {"type": ["string", "null"]},
        "pair_address": {"type": ["string", "null"]},
        "symbol": {"type": ["string", "null"]}
      }
    },
    "creator_wallet": {"type": ["string", "null"]},
    "dev_wallet": {"type": ["string", "null"]},
    "early_buyer_wallets": {
      "type": ["array", "null"],
      "items": {"type": "string"}
    },
    "shared_funders": {
      "type": ["array", "null"],
      "items": {"type": "string"}
    },
    "shared_launch_groups": {
      "type": ["array", "null"],
      "items": {"type": "string"}
    },
    "shared_cluster_ids": {
      "type": ["array", "null"],
      "items": {"type": "string"}
    },
    "direct_creator_links": {
      "type": ["array", "null"],
      "items": {"type": "string"}
    },
    "direct_dev_links": {
      "type": ["array", "null"],
      "items": {"type": "string"}
    },
    "funder_overlap_count": {"type": ["integer", "null"], "minimum": 0},
    "creator_dev_same_funder_flag": {"type": ["boolean", "null"]},
    "creator_buyer_same_funder_flag": {"type": ["boolean", "null"]},
    "dev_buyer_same_funder_flag": {"type": ["boolean", "null"]},
    "creator_cluster_overlap_flag": {"type": ["boolean", "null"]},
    "dev_cluster_overlap_flag": {"type": ["boolean", "null"]},
    "creator_dev_link_score": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
    "creator_buyer_link_score": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
    "dev_buyer_link_score": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
    "shared_funder_link_score": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
    "creator_cluster_link_score": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
    "cluster_dev_link_score": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
    "linkage_risk_score": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
    "creator_in_cluster_flag": {"type": ["boolean", "null"]},
    "creator_funder_overlap_count": {"type": ["integer", "null"], "minimum": 0},
    "buyer_funder_overlap_count": {"type": ["integer", "null"], "minimum": 0},
    "linkage_reason_codes": {
      "type": "array",
      "items": {"type": "string"}
    },
    "linkage_confidence": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
    "linkage_metric_origin": {
      "type": "string",
      "enum": ["graph_evidence", "heuristic_evidence", "mixed_evidence", "missing"]
    },
    "linkage_status": {
      "type": "string",
      "enum": ["ok", "partial", "missing", "failed"]
    },
    "linkage_warning": {"type": ["string", "null"]}
  }
}
