{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "wallet_rollout_recommendation",
  "type": "object",
  "required": [
    "recommendation",
    "recommendation_confidence",
    "primary_reasons",
    "blocking_risks",
    "next_mode",
    "safe_default_mode",
    "generated_at"
  ],
  "properties": {
    "recommendation": {
      "type": "string",
      "enum": ["keep_off", "keep_shadow", "promote_to_on", "rollback_to_off"]
    },
    "recommendation_confidence": {"type": "string", "enum": ["low", "medium", "high"]},
    "primary_reasons": {
      "type": "array",
      "items": {"type": "string"}
    },
    "blocking_risks": {
      "type": "array",
      "items": {"type": "string"}
    },
    "next_mode": {"type": "string", "enum": ["off", "shadow", "on"]},
    "safe_default_mode": {"type": "string", "const": "shadow"},
    "generated_at": {"type": "string"}
  },
  "additionalProperties": true
}
