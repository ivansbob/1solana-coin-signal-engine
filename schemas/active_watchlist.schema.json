{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "active_watchlist",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "generated_at", "watchlist_summary", "wallets"],
  "properties": {
    "contract_version": { "type": "string", "const": "active_watchlist.v1" },
    "generated_at": { "type": "string", "minLength": 1 },
    "watchlist_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_watchlist_size", "selected_wallets", "active_wallets", "watch_wallets"],
      "properties": {
        "max_watchlist_size": { "type": "integer", "minimum": 0 },
        "selected_wallets": { "type": "integer", "minimum": 0 },
        "active_wallets": { "type": "integer", "minimum": 0 },
        "watch_wallets": { "type": "integer", "minimum": 0 }
      }
    },
    "wallets": {
      "type": "array",
      "items": { "$ref": "smart_wallet_registry.schema.json#/$defs/walletRecord" }
    }
  }
}
