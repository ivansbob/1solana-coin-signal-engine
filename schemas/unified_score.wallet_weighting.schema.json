{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Unified Score With Wallet Weighting",
  "type": "object",
  "required": [
    "final_score_pre_wallet",
    "wallet_score_explain",
    "wallet_weighting_mode",
    "wallet_score_component_reason",
    "wallet_score_component_raw",
    "wallet_score_component_capped",
    "wallet_weighting_effective_mode",
    "wallet_registry_status",
    "wallet_score_component_applied_shadow",
    "wallet_score_component_applied",
    "final_score"
  ],
  "properties": {
    "mint": {
      "type": [
        "string",
        "null"
      ]
    },
    "token_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "symbol": {
      "type": [
        "string",
        "null"
      ]
    },
    "final_score_pre_wallet": {
      "type": "number"
    },
    "final_score": {
      "type": "number"
    },
    "wallet_weighting_mode": {
      "enum": [
        "off",
        "shadow",
        "on"
      ]
    },
    "wallet_weighting_effective_mode": {
      "enum": [
        "off",
        "shadow",
        "on",
        "degraded_zero"
      ]
    },
    "wallet_score_component_raw": {
      "type": "number"
    },
    "wallet_score_component_applied": {
      "type": "number"
    },
    "wallet_score_component_capped": {
      "type": "boolean"
    },
    "wallet_score_component_reason": {
      "type": "string"
    },
    "wallet_registry_status": {
      "type": "string"
    },
    "wallet_score_explain": {
      "type": "object",
      "required": [
        "smart_wallet_score_sum",
        "smart_wallet_tier1_hits",
        "smart_wallet_tier2_hits",
        "smart_wallet_tier3_hits",
        "smart_wallet_early_entry_hits",
        "smart_wallet_active_hits",
        "smart_wallet_watch_hits",
        "smart_wallet_conviction_bonus",
        "smart_wallet_registry_confidence",
        "wallet_adjustment_cap",
        "degraded_wallet_registry"
      ],
      "properties": {
        "smart_wallet_score_sum": {
          "type": "number"
        },
        "smart_wallet_tier1_hits": {
          "type": "integer"
        },
        "smart_wallet_tier2_hits": {
          "type": "integer"
        },
        "smart_wallet_tier3_hits": {
          "type": "integer"
        },
        "smart_wallet_early_entry_hits": {
          "type": "integer"
        },
        "smart_wallet_active_hits": {
          "type": "integer"
        },
        "smart_wallet_watch_hits": {
          "type": "integer"
        },
        "smart_wallet_conviction_bonus": {
          "type": "number"
        },
        "smart_wallet_registry_confidence": {
          "type": [
            "string",
            "null"
          ]
        },
        "wallet_adjustment_cap": {
          "type": "number"
        },
        "degraded_wallet_registry": {
          "type": "boolean"
        },
        "smart_wallet_netflow_bias": {
          "type": [
            "number",
            "string",
            "null",
            "boolean"
          ]
        }
      },
      "additionalProperties": true
    },
    "wallet_score_component_applied_shadow": {
      "type": "number"
    },
    "token_address": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": true
}
