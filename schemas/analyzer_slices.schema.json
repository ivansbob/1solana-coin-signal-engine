{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/analyzer_slices.schema.json",
  "title": "Analyzer slices payload",
  "type": "object",
  "required": ["metadata", "slice_groups", "recommendation_inputs", "status", "coverage"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["contract_version", "minimum_sample", "row_count"],
      "properties": {
        "contract_version": {"type": "string"},
        "run_id": {"type": "string"},
        "source": {"type": "string"},
        "as_of": {"type": ["string", "null"]},
        "minimum_sample": {"type": "integer", "minimum": 1},
        "row_count": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": true
    },
    "slice_groups": {
      "type": "object",
      "properties": {
        "regime": {"$ref": "#/$defs/sliceGroup"},
        "cluster_bundle": {"$ref": "#/$defs/sliceGroup"},
        "continuation": {"$ref": "#/$defs/sliceGroup"},
        "degraded_x": {"$ref": "#/$defs/sliceGroup"},
        "evidence_quality": {"$ref": "#/$defs/sliceGroup"},
        "exit_failure": {"$ref": "#/$defs/sliceGroup"}
      },
      "additionalProperties": {"$ref": "#/$defs/sliceGroup"}
    },
    "evidence_quality_slices": {"$ref": "#/$defs/sliceGroup"},
    "recommendation_inputs": {
      "type": "object",
      "required": ["actionable_slices", "low_sample_slices", "warnings", "manual_only"],
      "properties": {
        "actionable_slices": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["group", "slice_name", "sample_size", "confidence", "recommendation_hint"],
            "properties": {
              "group": {"type": "string"},
              "slice_name": {"type": "string"},
              "sample_size": {"type": "integer", "minimum": 0},
              "expectancy": {"type": ["number", "null"]},
              "confidence": {"type": ["string", "null"]},
              "recommendation_hint": {"type": "string"}
            },
            "additionalProperties": true
          }
        },
        "low_sample_slices": {"type": "array", "items": {"type": "string"}},
        "warnings": {"type": "array", "items": {"type": "string"}},
        "manual_only": {"type": "boolean"}
      },
      "additionalProperties": true
    },
    "status": {"type": "string"},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "coverage": {
      "type": "object",
      "required": ["available_groups", "low_confidence_slice_count"],
      "properties": {
        "available_groups": {"type": "array", "items": {"type": "string"}},
        "low_confidence_slice_count": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "sliceGroup": {
      "type": "object",
      "additionalProperties": {
        "anyOf": [
          {"$ref": "#/$defs/sliceMetric"},
          {
            "type": "object",
            "properties": {
              "slice_name": {"type": "string"},
              "sample_size": {"type": "integer", "minimum": 0},
              "status": {"type": "string"},
              "confidence": {"type": ["string", "null"]},
              "warnings": {"type": "array", "items": {"type": "string"}}
            },
            "additionalProperties": true
          }
        ]
      }
    },
    "sliceMetric": {
      "type": "object",
      "required": ["slice_name", "sample_size", "supporting_rows", "confidence", "status", "warnings", "interpretation"],
      "properties": {
        "slice_name": {"type": "string"},
        "sample_size": {"type": "integer", "minimum": 0},
        "supporting_rows": {"type": "array", "items": {"type": "string"}},
        "winrate": {"type": ["number", "null"]},
        "expectancy": {"type": ["number", "null"]},
        "median_pnl_pct": {"type": ["number", "null"]},
        "mean_pnl_pct": {"type": ["number", "null"]},
        "false_positive_rate": {"type": ["number", "null"]},
        "confidence": {"type": ["string", "null"]},
        "status": {"type": "string"},
        "warnings": {"type": "array", "items": {"type": "string"}},
        "interpretation": {"type": "string"},
        "recommendation_hint": {"type": ["string", "null"]}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
