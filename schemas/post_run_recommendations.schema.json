{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "post_run_recommendations",
  "type": "object",
  "required": ["recommendations", "contract_version"],
  "properties": {
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "target", "suggested_action", "confidence", "reason"],
        "properties": {
          "type": {"type": "string"},
          "target": {"type": "string"},
          "suggested_action": {"type": "string"},
          "confidence": {"type": "number"},
          "reason": {"type": "string"}
        }
      }
    },
    "contract_version": {"type": "string"}
  }
}
