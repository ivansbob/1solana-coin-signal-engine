{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ContractParityReport",
  "type": "object",
  "required": [
    "metadata",
    "summary",
    "contract_groups",
    "docs_sync",
    "events"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "required": [
        "tool_version",
        "generated_at",
        "repo_root"
      ],
      "properties": {
        "tool_version": {
          "type": "string"
        },
        "generated_at": {
          "type": "string"
        },
        "repo_root": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": [
        "overall_status",
        "contract_groups_checked",
        "artifacts_checked",
        "ok_count",
        "warning_count",
        "mismatch_count",
        "missing_count",
        "malformed_count",
        "empty_count",
        "events_emitted"
      ],
      "properties": {
        "overall_status": {
          "type": "string",
          "enum": [
            "ok",
            "warning",
            "empty",
            "mismatch",
            "missing",
            "malformed"
          ]
        },
        "contract_groups_checked": {
          "type": "integer"
        },
        "artifacts_checked": {
          "type": "integer"
        },
        "ok_count": {
          "type": "integer"
        },
        "warning_count": {
          "type": "integer"
        },
        "mismatch_count": {
          "type": "integer"
        },
        "missing_count": {
          "type": "integer"
        },
        "malformed_count": {
          "type": "integer"
        },
        "empty_count": {
          "type": "integer"
        },
        "events_emitted": {
          "type": "integer"
        }
      },
      "additionalProperties": false
    },
    "contract_groups": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "contract_group",
          "artifact_name",
          "artifact_path",
          "required_fields",
          "optional_fields",
          "present_fields",
          "present_any_fields",
          "missing_required_fields",
          "missing_optional_fields",
          "extra_fields",
          "row_count",
          "status",
          "warnings",
          "docs_sync_notes"
        ],
        "properties": {
          "contract_group": {
            "type": "string"
          },
          "artifact_name": {
            "type": "string"
          },
          "artifact_path": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "required_fields": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "optional_fields": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "present_fields": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "present_any_fields": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "missing_required_fields": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "missing_optional_fields": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "extra_fields": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "row_count": {
            "type": "integer"
          },
          "status": {
            "type": "string",
            "enum": [
              "ok",
              "warning",
              "empty",
              "mismatch",
              "missing",
              "malformed"
            ]
          },
          "warnings": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "docs_sync_notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "invalid_required_values": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "additionalProperties": false
      }
    },
    "docs_sync": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        },
        "missing_artifacts_in_readme": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missing_artifacts_in_contracts_doc": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stale_references": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "readme_path": {
          "type": "string"
        },
        "contracts_doc_path": {
          "type": "string"
        },
        "expected_artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "documented_artifacts_readme": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "documented_artifacts_contracts_doc": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "extra_documented_artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missing_contract_group_headings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missing_tool_references": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "event",
          "ts"
        ],
        "properties": {
          "event": {
            "type": "string"
          },
          "ts": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
