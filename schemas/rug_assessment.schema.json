{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Rug assessment token record",
  "type": "object",
  "required": [
    "token_address",
    "mint_revoked",
    "freeze_revoked",
    "lp_burn_confirmed",
    "lp_locked_flag",
    "top1_holder_share",
    "top20_holder_share",
    "dev_sell_pressure_5m",
    "rug_score",
    "rug_verdict",
    "rug_flags",
    "rug_warnings",
    "rug_status",
    "assessed_at",
    "contract_version"
  ],
  "properties": {
    "token_address": {"type": "string", "minLength": 1},
    "mint_revoked": {"type": "boolean"},
    "freeze_revoked": {"type": "boolean"},
    "lp_burn_confirmed": {"type": "boolean"},
    "lp_locked_flag": {"type": "boolean"},
    "top1_holder_share": {"type": "number", "minimum": 0, "maximum": 1},
    "top20_holder_share": {"type": "number", "minimum": 0, "maximum": 1},
    "dev_sell_pressure_5m": {"type": "number", "minimum": 0, "maximum": 1},
    "rug_score": {"type": "number", "minimum": 0, "maximum": 1},
    "rug_verdict": {"type": "string", "enum": ["PASS", "WATCH", "IGNORE"]},
    "rug_flags": {"type": "array", "items": {"type": "string"}},
    "rug_warnings": {"type": "array", "items": {"type": "string"}},
    "rug_status": {"type": "string", "enum": ["ok", "partial"]},
    "assessed_at": {"type": "string"},
    "contract_version": {"type": "string", "const": "rug_safety_v1"}
  },
  "additionalProperties": true
}
