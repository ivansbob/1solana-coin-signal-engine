    "symbol": {
      "type": [
        "string",
        "null"
      ]
    },
    "name": {
      "type": [
        "string",
        "null"
      ]
    },
    "bundle_count_first_60s": {
      "type": [
        "integer",
        "null"
      ]
    },
    "bundle_size_value": {
      "type": [
        "number",
        "null"
      ]
    },
    "unique_wallets_per_bundle_avg": {
      "type": [
        "number",
        "null"
      ]
    },
    "bundle_timing_from_liquidity_add_min": {
      "type": [
        "number",
        "null"
      ]
    },
    "bundle_success_rate": {
      "type": [
        "number",
        "null"
      ]
    },
    "bundle_composition_dominant": {
      "type": [
        "string",
        "null"
      ]
    },
    "bundle_tip_efficiency": {
      "type": [
        "number",
        "null"
      ]
    },
    "bundle_failure_retry_pattern": {
      "type": [
        "integer",
        "null"
      ]
    },
    "cross_block_bundle_correlation": {
      "type": [
        "number",
        "null"
      ]
