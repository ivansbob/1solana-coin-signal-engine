      "type": [
        "integer",
        "null"
      ]
    },
    "creator_in_cluster_flag": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "entry_decision": {
      "type": "string",
      "enum": [
        "SCALP",
        "TREND",
        "IGNORE"
      ]
    },
    "entry_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "recommended_position_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "entry_reason": {
      "type": "string",
      "minLength": 1
    },
    "entry_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "entry_warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "regime_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "regime_reason_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "regime_blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "expected_hold_class": {
      "type": "string",
      "enum": [
        "short",
        "medium",
        "long",
        "none"
      ]
    },
    "entry_snapshot": {
      "type": "object"
    },
    "entry_status": {
      "type": "string"
    },
    "decided_at": {
      "type": "string"
    },
    "contract_version": {
      "type": "string"
    },
    "smart_wallet_family_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "smart_wallet_independent_family_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "smart_wallet_family_origins": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "smart_wallet_family_statuses": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "smart_wallet_family_reason_codes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "smart_wallet_family_unique_count": {
      "type": "integer",
      "minimum": 0
    },
    "smart_wallet_independent_family_unique_count": {
      "type": "integer",
      "minimum": 0
    },
    "smart_wallet_family_confidence_max": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "smart_wallet_family_member_count_max": {
      "type": "integer",
      "minimum": 0
    },
    "smart_wallet_family_shared_funder_flag": {
      "type": "boolean"
    },
    "smart_wallet_family_creator_link_flag": {
      "type": "boolean"
    }
