{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/offline_feature_importance.schema.json",
  "title": "Offline Feature Importance",
  "type": "object",
  "required": [
    "analysis_contract_version",
    "generated_at_utc",
    "analysis_only",
    "not_for_online_decisioning",
    "association_only",
    "input_artifact",
    "method_definitions",
    "target_definitions",
    "targets",
    "warnings",
    "caveats"
  ],
  "properties": {
    "analysis_contract_version": {"type": "string"},
    "generated_at_utc": {"type": "string"},
    "analysis_only": {"const": true},
    "not_for_online_decisioning": {"const": true},
    "association_only": {"const": true},
    "input_artifact": {
      "type": "object",
      "required": [
        "path",
        "row_count",
        "total_rows_seen",
        "excluded_row_count",
        "malformed_row_count",
        "excluded_rows"
      ],
      "properties": {
        "path": {"type": ["string", "null"]},
        "row_count": {"type": "integer", "minimum": 0},
        "total_rows_seen": {"type": "integer", "minimum": 0},
        "excluded_row_count": {"type": "integer", "minimum": 0},
        "malformed_row_count": {"type": "integer", "minimum": 0},
        "excluded_rows": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["line_number", "reason"],
            "properties": {
              "line_number": {"type": "integer", "minimum": 1},
              "reason": {"type": "string"}
            }
          }
        }
      }
    },
    "method_definitions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["method", "description"],
        "properties": {
          "method": {"type": "string"},
          "description": {"type": "string"}
        }
      }
    },
    "target_definitions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "target_name",
          "target_type",
          "description",
          "sample_size",
          "positive_count",
          "negative_count",
          "warnings"
        ],
        "properties": {
          "target_name": {"type": "string"},
          "target_type": {"type": "string"},
          "description": {"type": "string"},
          "sample_size": {"type": "integer", "minimum": 0},
          "positive_count": {"type": "integer", "minimum": 0},
          "negative_count": {"type": "integer", "minimum": 0},
          "warnings": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["target_name", "grouped_importance", "per_feature_importance", "warnings"],
        "properties": {
          "target_name": {"type": "string"},
          "warnings": {"type": "array", "items": {"type": "string"}},
          "grouped_importance": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "feature_group",
                "target_name",
                "feature_count",
                "importance_score_total",
                "importance_score_avg",
                "coverage_ratio_avg",
                "top_features"
              ],
              "properties": {
                "feature_group": {"type": "string"},
                "target_name": {"type": "string"},
                "feature_count": {"type": "integer", "minimum": 0},
                "importance_score_total": {"type": "number"},
                "importance_score_avg": {"type": "number"},
                "coverage_ratio_avg": {"type": "number"},
                "top_features": {"type": "array", "items": {"type": "string"}}
              }
            }
          },
          "per_feature_importance": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "feature_name",
                "feature_group",
                "importance_score",
                "coverage_ratio",
                "missing_ratio",
                "direction_hint",
                "target_name",
                "method",
                "status",
                "observed_rows",
                "warnings",
                "importance_rank"
              ],
              "properties": {
                "feature_name": {"type": "string"},
                "feature_group": {"type": "string"},
                "importance_score": {"type": "number"},
                "coverage_ratio": {"type": "number"},
                "missing_ratio": {"type": "number"},
                "direction_hint": {"type": ["string", "null"]},
                "target_name": {"type": "string"},
                "method": {"type": "string"},
                "status": {"type": "string"},
                "observed_rows": {"type": "integer", "minimum": 0},
                "importance_rank": {"type": "integer", "minimum": 1},
                "warnings": {"type": "array", "items": {"type": "string"}}
              }
            }
          }
        }
      }
    },
    "warnings": {"type": "array", "items": {"type": "string"}},
    "caveats": {"type": "array", "items": {"type": "string"}}
  }
}
