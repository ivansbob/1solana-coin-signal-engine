{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "replay_validation_report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "generated_at",
    "input_summary",
    "replay_summary",
    "promotion_summary",
    "tier_change_summary",
    "notes"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "const": "wallet_replay_validation.v1"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "input_summary": {
      "type": "object",
      "additionalProperties": true,
      "required": ["registry_wallets"]
    },
    "replay_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_wallets_evaluated",
        "wallets_with_wallet_specific_evidence",
        "wallets_without_sufficient_evidence",
        "wallets_promoted",
        "wallets_demoted",
        "wallets_held",
        "wallets_watch_pending_validation",
        "aggregate_expectancy_if_available",
        "aggregate_winrate_if_available"
      ],
      "properties": {
        "total_wallets_evaluated": {"type": "integer", "minimum": 0},
        "wallets_with_wallet_specific_evidence": {"type": "integer", "minimum": 0},
        "wallets_without_sufficient_evidence": {"type": "integer", "minimum": 0},
        "wallets_promoted": {"type": "integer", "minimum": 0},
        "wallets_demoted": {"type": "integer", "minimum": 0},
        "wallets_held": {"type": "integer", "minimum": 0},
        "wallets_watch_pending_validation": {"type": "integer", "minimum": 0},
        "aggregate_expectancy_if_available": {"type": ["number", "null"]},
        "aggregate_winrate_if_available": {"type": ["number", "null"]}
      }
    },
    "promotion_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["promote", "demote", "hold", "watch_pending_validation", "reject"],
      "properties": {
        "promote": {"type": "integer", "minimum": 0},
        "demote": {"type": "integer", "minimum": 0},
        "hold": {"type": "integer", "minimum": 0},
        "watch_pending_validation": {"type": "integer", "minimum": 0},
        "reject": {"type": "integer", "minimum": 0}
      }
    },
    "tier_change_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tier_1_before",
        "tier_1_after",
        "tier_2_before",
        "tier_2_after",
        "tier_3_before",
        "tier_3_after"
      ],
      "properties": {
        "tier_1_before": {"type": "integer", "minimum": 0},
        "tier_1_after": {"type": "integer", "minimum": 0},
        "tier_2_before": {"type": "integer", "minimum": 0},
        "tier_2_after": {"type": "integer", "minimum": 0},
        "tier_3_before": {"type": "integer", "minimum": 0},
        "tier_3_after": {"type": "integer", "minimum": 0}
      }
    },
    "notes": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
