{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "XValidationOutput",
  "type": "object",
  "required": [
    "contract_version",
    "generated_at",
    "tokens"
  ],
  "properties": {
    "contract_version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "tokens": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "token_address",
          "x_status",
          "x_validation_score",
          "x_validation_delta",
          "contract_version"
        ],
        "properties": {
          "token_address": {
            "type": "string",
            "minLength": 1
          },
          "symbol": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "x_posts_visible": {
            "type": "number"
          },
          "x_unique_authors_visible": {
            "type": "number"
          },
          "x_weighted_engagement": {
            "type": "number"
          },
          "x_duplicate_text_ratio": {
            "type": "number"
          },
          "x_promoter_concentration": {
            "type": "number"
          },
          "x_official_account_match": {
            "type": "number"
          },
          "x_contract_mention_presence": {
            "type": "number"
          },
          "x_validation_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          },
          "x_validation_delta": {
            "type": "number"
          },
          "x_status": {
            "type": "string",
            "enum": [
              "ok",
              "empty",
              "degraded",
              "captcha",
              "login_required",
              "timeout",
              "blocked",
              "error"
            ]
          },
          "x_queries_attempted": {
            "type": "integer"
          },
          "x_queries_succeeded": {
            "type": "integer"
          },
          "x_cache_hit": {
            "type": "boolean"
          },
          "x_snapshot_at": {
            "type": "string"
          },
          "contract_version": {
            "type": "string"
          },
          "x_author_velocity_5m": {
            "type": [
              "number",
              "null"
            ]
          }
        }
      }
    }
  }
}
