{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "normalized_wallet_candidates",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "generated_at",
    "input_summary",
    "candidates"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "const": "wallet_seed_import.v1"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "input_summary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "total_rows_seen",
        "valid_wallets",
        "invalid_rows",
        "duplicates_removed"
      ],
      "properties": {
        "total_rows_seen": { "type": "integer", "minimum": 0 },
        "valid_wallets": { "type": "integer", "minimum": 0 },
        "invalid_rows": { "type": "integer", "minimum": 0 },
        "duplicates_removed": { "type": "integer", "minimum": 0 }
      }
    },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "wallet",
          "status",
          "source_names",
          "source_count",
          "source_records",
          "imported_at",
          "manual_priority"
        ],
        "properties": {
          "wallet": { "type": "string", "minLength": 1 },
          "status": { "type": "string" },
          "source_names": { "type": "array", "items": { "type": "string" } },
          "source_count": { "type": "integer", "minimum": 1 },
          "source_records": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "required": ["source_name", "source_type", "file_path", "raw_fields"],
              "properties": {
                "source_name": { "type": "string" },
                "source_type": { "type": "string", "enum": ["manual_csv", "manual_txt", "manual_json"] },
                "file_path": { "type": "string", "minLength": 1 },
                "observed_label": { "type": ["string", "null"] },
                "observed_at": { "type": ["string", "null"] },
                "raw_fields": { "type": "object" }
              }
            }
          },
          "imported_at": { "type": "string", "minLength": 1 },
          "manual_priority": { "type": "boolean" }
        }
      }
    }
  }
}
