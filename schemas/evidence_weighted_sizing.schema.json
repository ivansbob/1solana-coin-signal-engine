{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EvidenceWeightedSizing",
  "type": "object",
  "required": [
    "contract_version",
    "generated_at",
    "signal_id",
    "token_address",
    "base_position_pct",
    "effective_position_pct",
    "sizing_multiplier",
    "sizing_reason_codes",
    "sizing_confidence",
    "sizing_origin",
    "evidence_quality_score",
    "evidence_conflict_flag",
    "partial_evidence_flag"
  ],
  "properties": {
    "contract_version": {"type": "string", "const": "evidence_weighted_sizing.v1"},
    "generated_at": {"type": "string", "minLength": 1},
    "metadata": {"type": ["object", "null"]},
    "metadata_status": {"type": ["string", "null"]},
    "signal_id": {"type": ["string", "null"]},
    "token_address": {"type": ["string", "null"]},
    "pair_address": {"type": ["string", "null"]},
    "symbol": {"type": ["string", "null"]},
    "base_position_pct": {"type": "number", "minimum": 0, "maximum": 1},
    "effective_position_pct": {"type": "number", "minimum": 0, "maximum": 1},
    "sizing_multiplier": {"type": "number", "minimum": 0, "maximum": 1},
    "sizing_reason_codes": {"type": "array", "items": {"type": "string"}},
    "sizing_confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "sizing_origin": {
      "type": "string",
      "enum": [
        "mode_policy_only",
        "degraded_x_policy",
        "evidence_weighted",
        "partial_evidence_reduced",
        "risk_reduced"
      ]
    },
    "sizing_warning": {"type": ["string", "null"]},
    "evidence_quality_score": {"type": "number", "minimum": 0, "maximum": 1},
    "evidence_conflict_flag": {"type": "boolean"},
    "partial_evidence_flag": {"type": "boolean"},
    "evidence_coverage_ratio": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
    "evidence_available": {"type": ["array", "null"], "items": {"type": "string"}},
    "evidence_scores": {"type": ["object", "null"], "additionalProperties": {"type": "number"}},
    "policy_origin": {"type": ["string", "null"]},
    "warnings": {"type": ["array", "null"], "items": {"type": "string"}},
    "signal_linkage": {
      "type": ["object", "null"],
      "properties": {
        "run_id": {"type": ["string", "null"]},
        "source_artifact": {"type": ["string", "null"]},
        "runtime_signal_origin": {"type": ["string", "null"]}
      },
      "additionalProperties": true
    },
    "evidence_quality_summary": {
      "type": ["object", "null"],
      "properties": {
        "coverage_ratio": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "confidence": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "warnings": {"type": ["array", "null"], "items": {"type": "string"}}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
