{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "wallet_clusters.schema.json",
  "title": "Wallet Cluster Artifact",
  "type": "object",
  "required": ["metadata", "clusters", "wallet_to_cluster", "summary"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["generated_at", "contract_version"],
      "properties": {
        "generated_at": {"type": "string"},
        "contract_version": {"type": "string"},
        "derivation_mode": {"type": "string"}
      },
      "additionalProperties": true
    },
    "clusters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["cluster_id", "wallet_count", "edge_count", "derived_from", "cluster_confidence"],
        "properties": {
          "cluster_id": {"type": "string"},
          "wallets": {"type": "array", "items": {"type": "string"}},
          "wallet_count": {"type": "integer"},
          "edge_count": {"type": "integer"},
          "evidence_types": {"type": "array", "items": {"type": "string"}},
          "funding_sources_seen": {"type": "array", "items": {"type": "string"}},
          "launches_seen": {"type": "array", "items": {"type": "string"}},
          "creator_linked_flag": {"type": "boolean"},
          "derived_from": {"type": "string"},
          "cluster_confidence": {"type": "number"}
        },
        "additionalProperties": true
      }
    },
    "wallet_to_cluster": {
      "type": "object",
      "additionalProperties": {"type": "string"}
    },
    "summary": {
      "type": "object",
      "properties": {
        "cluster_count": {"type": "integer"},
        "wallet_coverage_count": {"type": "integer"},
        "node_count": {"type": "integer"},
        "edge_count": {"type": "integer"}
      },
      "additionalProperties": true
    },
    "warnings": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
