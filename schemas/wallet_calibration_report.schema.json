{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "wallet_calibration_report",
  "type": "object",
  "required": [
    "contract_version",
    "generated_at",
    "input_summary",
    "mode_comparison",
    "robustness_checks",
    "recommendation",
    "notes"
  ],
  "properties": {
    "contract_version": {"type": "string", "const": "wallet_weighting_calibration_v1"},
    "generated_at": {"type": "string"},
    "input_summary": {"type": "object"},
    "mode_comparison": {"type": "object"},
    "robustness_checks": {
      "type": "object",
      "required": [
        "sample_size_confidence",
        "outlier_concentration_flag",
        "degraded_registry_share",
        "score_shift_concentration",
        "recommendation_confidence"
      ],
      "properties": {
        "sample_size_confidence": {"type": "string", "enum": ["none", "low", "medium", "high"]},
        "outlier_concentration_flag": {"type": "boolean"},
        "degraded_registry_share": {"type": "object"},
        "score_shift_concentration": {"type": "object"},
        "recommendation_confidence": {"type": "string", "enum": ["low", "medium", "high"]}
      },
      "additionalProperties": true
    },
    "recommendation": {"$ref": "./wallet_rollout_recommendation.schema.json"},
    "notes": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "additionalProperties": true
}
