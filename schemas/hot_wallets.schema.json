{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "hot_wallets",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "generated_at", "hot_summary", "wallets"],
  "properties": {
    "contract_version": { "type": "string", "const": "hot_wallets.v1" },
    "generated_at": { "type": "string", "minLength": 1 },
    "hot_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_hot_wallets_size", "selected_wallets", "tier_1_wallets", "tier_2_wallets", "tier_3_wallets"],
      "properties": {
        "max_hot_wallets_size": { "type": "integer", "minimum": 0 },
        "selected_wallets": { "type": "integer", "minimum": 0 },
        "tier_1_wallets": { "type": "integer", "minimum": 0 },
        "tier_2_wallets": { "type": "integer", "minimum": 0 },
        "tier_3_wallets": { "type": "integer", "minimum": 0 }
      }
    },
    "wallets": {
      "type": "array",
      "items": { "$ref": "smart_wallet_registry.schema.json#/$defs/walletRecord" }
    }
  }
}
