{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "smart_wallet_registry_validated",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "generated_at",
    "input_summary",
    "replay_summary",
    "wallets"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "const": "smart_wallet_registry_validated.v1"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "input_summary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "registry_wallets"
      ]
    },
    "replay_summary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "total_wallets_evaluated",
        "wallets_with_wallet_specific_evidence",
        "wallets_without_sufficient_evidence",
        "wallets_promoted",
        "wallets_demoted",
        "wallets_held",
        "wallets_watch_pending_validation"
      ]
    },
    "wallets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/validatedWalletRecord"
      }
    },
    "wallet_family_summary": {
      "$ref": "wallet_family_metadata.schema.json#/$defs/summary"
    },
    "wallet_family_assignments": {
      "type": "array",
      "items": {
        "$ref": "wallet_family_metadata.schema.json#/$defs/familyAssignment"
      }
    }
  },
  "$defs": {
    "validatedWalletRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wallet",
        "previous_tier",
        "new_tier",
        "previous_status",
        "new_status",
        "registry_score",
        "replay_evidence",
        "promotion_decision",
        "promotion_reason",
        "source_names",
        "source_count",
        "tags",
        "notes",
        "updated_at",
        "wallet_family_id",
        "independent_family_id",
        "wallet_family_confidence",
        "wallet_family_origin",
        "wallet_family_reason_codes",
        "wallet_cluster_id",
        "wallet_family_member_count",
        "wallet_family_shared_funder_flag",
        "wallet_family_creator_link_flag",
        "wallet_family_status"
      ],
      "properties": {
        "wallet": {
          "type": "string",
          "minLength": 1
        },
        "previous_tier": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "tier_1",
            "tier_2",
            "tier_3",
            "rejected",
            null
          ]
        },
        "new_tier": {
          "type": "string",
          "enum": [
            "tier_1",
            "tier_2",
            "tier_3",
            "rejected"
          ]
        },
        "previous_status": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "active",
            "watch",
            "watch_pending_validation",
            "rejected",
            null
          ]
        },
        "new_status": {
          "type": "string",
          "enum": [
            "active",
            "watch",
            "watch_pending_validation",
            "rejected"
          ]
        },
        "registry_score": {
          "type": "number"
        },
        "replay_evidence": {
          "$ref": "#/$defs/replayEvidence"
        },
        "promotion_decision": {
          "type": "string",
          "enum": [
            "promote",
            "demote",
            "hold",
            "watch_pending_validation",
            "reject"
          ]
        },
        "promotion_reason": {
          "type": "string",
          "minLength": 1
        },
        "source_names": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source_count": {
          "type": "integer",
          "minimum": 0
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        },
        "updated_at": {
          "type": "string",
          "minLength": 1
        },
        "wallet_family_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "independent_family_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "wallet_family_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "wallet_family_origin": {
          "$ref": "wallet_family_metadata.schema.json#/$defs/walletFamilyOrigin"
        },
        "wallet_family_reason_codes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "wallet_cluster_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "wallet_family_member_count": {
          "type": "integer",
          "minimum": 0
        },
        "wallet_family_shared_funder_flag": {
          "type": "boolean"
        },
        "wallet_family_creator_link_flag": {
          "type": "boolean"
        },
        "wallet_family_status": {
          "$ref": "wallet_family_metadata.schema.json#/$defs/walletFamilyStatus"
        }
      }
    },
    "replayEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wallet",
        "replay_tokens_seen",
        "replay_hits",
        "positive_outcome_hits",
        "negative_outcome_hits",
        "median_pnl_pct",
        "mean_pnl_pct",
        "winrate",
        "false_positive_rate",
        "expectancy",
        "avg_hold_sec",
        "evidence_score",
        "evidence_confidence",
        "promotion_decision",
        "promotion_reason",
        "last_validated_at"
      ],
      "properties": {
        "wallet": {
          "type": "string",
          "minLength": 1
        },
        "replay_tokens_seen": {
          "type": "integer",
          "minimum": 0
        },
        "replay_hits": {
          "type": "integer",
          "minimum": 0
        },
        "positive_outcome_hits": {
          "type": "integer",
          "minimum": 0
        },
        "negative_outcome_hits": {
          "type": "integer",
          "minimum": 0
        },
        "median_pnl_pct": {
          "type": [
            "number",
            "null"
          ]
        },
        "mean_pnl_pct": {
          "type": [
            "number",
            "null"
          ]
        },
        "winrate": {
          "type": [
            "number",
            "null"
          ]
        },
        "false_positive_rate": {
          "type": [
            "number",
            "null"
          ]
        },
        "expectancy": {
          "type": [
            "number",
            "null"
          ]
        },
        "avg_hold_sec": {
          "type": [
            "number",
            "null"
          ]
        },
        "evidence_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "evidence_confidence": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "promotion_decision": {
          "type": "string",
          "enum": [
            "promote",
            "demote",
            "hold",
            "watch_pending_validation",
            "reject"
          ]
        },
        "promotion_reason": {
          "type": "string",
          "minLength": 1
        },
        "last_validated_at": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
