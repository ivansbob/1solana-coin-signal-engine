{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bundle_evidence.schema.json",
  "title": "Bundle Evidence",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "bundle_evidence_status",
    "bundle_evidence_source",
    "bundle_evidence_warning",
    "bundle_evidence_collected_at",
    "bundle_window_anchor_ts",
    "bundle_window_sec",
    "bundle_records",
    "bundle_evidence_summary"
  ],
  "properties": {
    "bundle_evidence_status": {"type": ["string", "null"]},
    "bundle_evidence_source": {"type": ["string", "null"]},
    "bundle_evidence_warning": {"type": ["string", "null"]},
    "bundle_evidence_collected_at": {"type": ["string", "null"]},
    "bundle_window_anchor_ts": {"type": ["integer", "null"]},
    "bundle_window_sec": {"type": ["integer", "null"], "minimum": 1},
    "bundle_records": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "record_id": {"type": ["string", "null"]},
          "group_id": {"type": ["string", "number", "null"]},
          "attempt_id": {"type": ["string", "number", "null"]},
          "retry_of": {"type": ["string", "number", "null"]},
          "token_address": {"type": ["string", "null"]},
          "pair_address": {"type": ["string", "null"]},
          "slot": {"type": ["integer", "null"]},
          "block": {"type": ["integer", "null"]},
          "timestamp": {"type": ["integer", "null"]},
          "actor": {"type": ["string", "null"]},
          "wallet": {"type": ["string", "null"]},
          "status": {"type": "string", "enum": ["landed", "failed", "unknown"]},
          "side": {"type": ["string", "null"]},
          "notional": {"type": ["number", "null"]},
          "value": {"type": ["number", "null"]},
          "tip": {"type": ["number", "null"]},
          "priority_fee": {"type": ["number", "null"]},
          "provenance": {"type": ["object", "null"]}
        }
      }
    },
    "bundle_evidence_summary": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "raw_record_count": {"type": ["integer", "null"]},
        "normalized_record_count": {"type": ["integer", "null"]},
        "records_in_window": {"type": ["integer", "null"]},
        "malformed_record_count": {"type": ["integer", "null"]},
        "landed_record_count": {"type": ["integer", "null"]},
        "failed_record_count": {"type": ["integer", "null"]},
        "unknown_record_count": {"type": ["integer", "null"]},
        "actor_count": {"type": ["integer", "null"]},
        "explicit_group_count": {"type": ["integer", "null"]}
      }
    }
  }
}
