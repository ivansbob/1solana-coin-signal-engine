{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Transaction Lake Listing",
  "type": "object",
  "required": ["generated_at", "contract_version", "batches"],
  "properties": {
    "generated_at": {"type": "string"},
    "contract_version": {"type": "string"},
    "batches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["lookup_key", "lookup_type", "source_provider", "tx_batch_status", "tx_batch_record_count"],
        "properties": {
          "lookup_key": {"type": "string"},
          "lookup_type": {"type": "string"},
          "source_provider": {"type": "string"},
          "tx_batch_status": {"type": "string"},
          "tx_batch_freshness": {"type": ["string", "null"]},
          "tx_batch_record_count": {"type": "integer", "minimum": 0},
          "path": {"type": ["string", "null"]}
        }
      }
    }
  }
}
