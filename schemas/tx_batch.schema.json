{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Transaction Batch",
  "type": "object",
  "required": [
    "contract_version",
    "source_provider",
    "lookup_key",
    "lookup_type",
    "fetched_at",
    "normalized_at",
    "freshness_status",
    "batch_status",
    "warnings",
    "record_count",
    "tx_records"
  ],
  "properties": {
    "contract_version": {"type": "string"},
    "source_provider": {"type": "string"},
    "lookup_key": {"type": "string"},
    "lookup_type": {"type": "string"},
    "fetched_at": {"type": "string"},
    "normalized_at": {"type": "string"},
    "freshness_status": {"type": "string"},
    "batch_status": {"type": "string"},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "record_count": {"type": "integer", "minimum": 0},
    "tx_records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["signature", "lookup_key", "lookup_type", "source_provider"],
        "properties": {
          "signature": {"type": "string"},
          "timestamp": {"type": ["integer", "null"]},
          "slot": {"type": ["integer", "null"]},
          "success": {"type": ["boolean", "null"]},
          "feePayer": {"type": ["string", "null"]},
          "tokenTransfers": {"type": "array"},
          "nativeTransfers": {"type": "array"},
          "lookup_key": {"type": "string"},
          "lookup_type": {"type": "string"},
          "source_provider": {"type": "string"}
        }
      }
    }
  }
}
