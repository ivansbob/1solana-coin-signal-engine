{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ContinuationEnrichmentPayload",
  "type": "object",
  "required": [
    "metadata",
    "token",
    "continuation_metrics",
    "provenance",
    "events"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "required": [
        "contract_version",
        "generated_at"
      ],
      "properties": {
        "contract_version": {
          "type": "string"
        },
        "generated_at": {
          "type": "string"
        }
      }
    },
    "token": {
      "type": "object",
      "required": [
        "token_address",
        "pair_address"
      ],
      "properties": {
        "token_address": {
          "type": [
            "string",
            "null"
          ]
        },
        "pair_address": {
          "type": [
            "string",
            "null"
          ]
        },
        "symbol": {
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "type": [
            "string",
            "null"
          ]
        },
        "pair_created_at": {
          "type": [
            "string",
            "integer",
            "null"
          ]
        }
      }
    },
    "continuation_metrics": {
      "type": "object",
      "required": [
        "net_unique_buyers_60s",
        "liquidity_refill_ratio_120s",
        "cluster_sell_concentration_120s",
        "smart_wallet_dispersion_score",
        "x_author_velocity_5m",
        "seller_reentry_ratio",
        "liquidity_shock_recovery_sec"
      ],
      "properties": {
        "net_unique_buyers_60s": {
          "type": ["integer", "null"]
        },
        "liquidity_refill_ratio_120s": {
          "type": ["number", "null"]
        },
        "cluster_sell_concentration_120s": {
          "type": ["number", "null"]
        },
        "smart_wallet_dispersion_score": {
          "type": ["number", "null"]
        },
        "x_author_velocity_5m": {
          "type": ["number", "null"]
        },
        "seller_reentry_ratio": {
          "type": ["number", "null"]
        },
        "liquidity_shock_recovery_sec": {
          "type": ["integer", "null"]
        }
      }
    },
    "provenance": {
      "type": "object",
      "required": [
        "continuation_status",
        "continuation_warning",
        "continuation_confidence",
        "continuation_metric_origin",
        "continuation_coverage_ratio",
        "continuation_inputs_status",
        "continuation_warnings",
        "continuation_available_evidence",
        "continuation_missing_evidence"
      ],
      "properties": {
        "continuation_status": {
          "type": "string",
          "enum": ["complete", "partial", "missing"]
        },
        "continuation_warning": {
          "type": "string"
        },
        "continuation_confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "continuation_metric_origin": {
          "type": "string",
          "enum": ["computed_from_tx", "computed_from_x", "computed_from_wallet_registry", "mixed_evidence", "partial", "missing"]
        },
        "continuation_coverage_ratio": {
          "type": "number"
        },
        "continuation_inputs_status": {
          "type": "object"
        },
        "continuation_warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "continuation_available_evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "continuation_missing_evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "ts",
          "event"
        ],
        "properties": {
          "ts": {
            "type": "string"
          },
          "event": {
            "type": "string"
          }
        }
      }
    }
  }
}
