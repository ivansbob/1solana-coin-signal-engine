{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PositionBook",
  "type": "object",
  "required": ["positions", "next_position_seq", "next_trade_seq"],
  "properties": {
    "positions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["position_id", "token_address", "is_open", "position_size_sol", "remaining_size_sol"],
        "properties": {
          "position_id": {"type": "string"},
          "token_address": {"type": "string"},
          "symbol": {"type": ["string", "null"]},
          "is_open": {"type": "boolean"},
          "position_size_sol": {"type": "number"},
          "remaining_size_sol": {"type": "number"}
        },
        "additionalProperties": true
      }
    },
    "next_position_seq": {"type": "integer", "minimum": 1},
    "next_trade_seq": {"type": "integer", "minimum": 1}
  },
  "additionalProperties": true
}
