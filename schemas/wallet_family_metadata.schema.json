{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "wallet_family_metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "generated_at",
    "wallet_records",
    "family_assignments",
    "family_summaries",
    "summary",
    "warnings"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "const": "wallet_family_metadata.v1"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "wallet_records": {
      "type": "array",
      "items": { "$ref": "#/$defs/walletFamilyWalletRecord" }
    },
    "family_assignments": {
      "type": "array",
      "items": { "$ref": "#/$defs/familyAssignment" }
    },
    "family_summaries": {
      "type": "array",
      "items": { "$ref": "#/$defs/familySummary" }
    },
    "summary": { "$ref": "#/$defs/summary" },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "walletFamilyOrigin": {
      "type": "string",
      "enum": [
        "graph_evidence",
        "linkage_evidence",
        "registry_evidence",
        "mixed_evidence",
        "heuristic_evidence",
        "missing"
      ]
    },
    "walletFamilyStatus": {
      "type": "string",
      "enum": ["ok", "partial", "missing", "failed"]
    },
    "walletFamilyWalletRecord": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "wallet",
        "wallet_family_id",
        "independent_family_id",
        "wallet_family_confidence",
        "wallet_family_origin",
        "wallet_family_reason_codes",
        "wallet_cluster_id",
        "wallet_family_member_count",
        "wallet_family_shared_funder_flag",
        "wallet_family_creator_link_flag",
        "wallet_family_status"
      ],
      "properties": {
        "wallet": { "type": "string", "minLength": 1 },
        "wallet_family_id": { "type": ["string", "null"] },
        "independent_family_id": { "type": ["string", "null"] },
        "wallet_family_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "wallet_family_origin": { "$ref": "#/$defs/walletFamilyOrigin" },
        "wallet_family_reason_codes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "wallet_cluster_id": { "type": ["string", "null"] },
        "wallet_family_member_count": { "type": "integer", "minimum": 0 },
        "wallet_family_shared_funder_flag": { "type": "boolean" },
        "wallet_family_creator_link_flag": { "type": "boolean" },
        "wallet_family_status": { "$ref": "#/$defs/walletFamilyStatus" }
      }
    },
    "familyAssignment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wallet_family_id",
        "family_type",
        "member_wallets",
        "member_count",
        "wallet_family_confidence",
        "wallet_family_origin",
        "wallet_family_reason_codes",
        "wallet_family_shared_funder_flag",
        "wallet_family_creator_link_flag",
        "wallet_family_status"
      ],
      "properties": {
        "wallet_family_id": { "type": "string", "minLength": 1 },
        "family_type": { "type": "string", "enum": ["wallet_family", "independent_family"] },
        "member_wallets": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "member_count": { "type": "integer", "minimum": 2 },
        "wallet_family_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "wallet_family_origin": { "$ref": "#/$defs/walletFamilyOrigin" },
        "wallet_family_reason_codes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "wallet_cluster_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "wallet_family_shared_funder_flag": { "type": "boolean" },
        "wallet_family_creator_link_flag": { "type": "boolean" },
        "wallet_family_status": { "$ref": "#/$defs/walletFamilyStatus" },
        "independent_family_ids": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "familySummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wallet_family_id",
        "member_count",
        "independent_family_count",
        "wallet_family_confidence",
        "wallet_family_origin",
        "wallet_family_status"
      ],
      "properties": {
        "wallet_family_id": { "type": "string", "minLength": 1 },
        "member_count": { "type": "integer", "minimum": 2 },
        "independent_family_count": { "type": "integer", "minimum": 0 },
        "wallet_family_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "wallet_family_origin": { "$ref": "#/$defs/walletFamilyOrigin" },
        "wallet_family_status": { "$ref": "#/$defs/walletFamilyStatus" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wallet_count",
        "family_count",
        "independent_family_count",
        "assigned_wallets",
        "independent_wallets",
        "strong_assignments",
        "weak_assignments",
        "missing_assignments",
        "failed_assignments",
        "partial_assignments",
        "ok_assignments",
        "origins",
        "warning_count",
        "family_assignment_rows"
      ],
      "properties": {
        "wallet_count": { "type": "integer", "minimum": 0 },
        "family_count": { "type": "integer", "minimum": 0 },
        "independent_family_count": { "type": "integer", "minimum": 0 },
        "assigned_wallets": { "type": "integer", "minimum": 0 },
        "independent_wallets": { "type": "integer", "minimum": 0 },
        "strong_assignments": { "type": "integer", "minimum": 0 },
        "weak_assignments": { "type": "integer", "minimum": 0 },
        "missing_assignments": { "type": "integer", "minimum": 0 },
        "failed_assignments": { "type": "integer", "minimum": 0 },
        "partial_assignments": { "type": "integer", "minimum": 0 },
        "ok_assignments": { "type": "integer", "minimum": 0 },
        "origins": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "warning_count": { "type": "integer", "minimum": 0 },
        "family_assignment_rows": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
