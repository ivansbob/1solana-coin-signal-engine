    "total_signals",
    "total_entries_attempted",
    "total_fills_successful",
    "total_positions_closed",
    "total_positions_open",
    "realized_pnl_sol",
    "unrealized_pnl_sol",
    "net_pnl_sol",
    "equity_sol",
    "winrate_total",
    "profit_factor_total",
    "exit_reason_distribution",
    "friction_summary",
    "metric_correlations",
    "warnings",
    "contract_version"
  ],
