    "as_of": {"type": "string"},
    "total_signals": {"type": "integer"},
    "total_entries_attempted": {"type": "integer"},
    "total_fills_successful": {"type": "integer"},
    "total_positions_closed": {"type": "integer"},
    "total_positions_open": {"type": "integer"},
    "realized_pnl_sol": {"type": "number"},
    "unrealized_pnl_sol": {"type": "number"},
    "net_pnl_sol": {"type": "number"},
    "equity_sol": {"type": "number"},
    "winrate_total": {"type": "number"},
    "profit_factor_total": {"type": "number"},
    "exit_reason_distribution": {"type": "object"},
    "friction_summary": {"type": "object"},
    "metric_correlations": {"type": "array"},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "contract_version": {"type": "string"}
  }
}
