{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/replay_harness.schema.json",
  "title": "Historical Replay Harness Summary",
  "type": "object",
  "required": [
    "artifact_truth_layer",
    "artifacts",
    "config_hash",
    "contract_version",
    "historical_input_hash",
    "historical_rows_used",
    "input_origin",
    "partial_rows",
    "replay_mode",
    "replay_score_source",
    "run_id",
    "score_contract_version",
    "signals",
    "status",
    "summary_markdown",
    "synthetic_fallback_used",
    "trade_feature_matrix_rows",
    "trades",
    "unresolved_rows",
    "wallet_mode_parity_status",
    "wallet_weighting",
    "wallet_weighting_effective_modes",
    "wallet_weighting_requested_mode"
  ],
  "properties": {
    "contract_version": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "replay_mode": {
      "type": "string",
      "enum": [
        "historical",
        "historical_partial",
        "synthetic_smoke",
        "mixed"
      ]
    },
    "input_origin": {
      "type": "string",
      "enum": [
        "historical",
        "historical_partial",
        "synthetic_smoke",
        "mixed"
      ]
    },
    "wallet_weighting": {
      "type": "string",
      "enum": [
        "off",
        "shadow",
        "on"
      ]
    },
    "config_hash": {
      "type": "string"
    },
    "historical_rows_used": {
      "type": "integer",
      "minimum": 0
    },
    "partial_rows": {
      "type": "integer",
      "minimum": 0
    },
    "unresolved_rows": {
      "type": "integer",
      "minimum": 0
    },
    "ignored_rows": {
      "type": "integer",
      "minimum": 0
    },
    "synthetic_fallback_used": {
      "type": "boolean"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifacts": {
      "type": "object",
      "required": [
        "signals",
        "trades",
        "positions",
        "trade_feature_matrix",
        "replay_summary",
        "replay_summary_md",
        "manifest"
      ],
      "properties": {
        "signals": {
          "type": "string"
        },
        "trades": {
          "type": "string"
        },
        "positions": {
          "type": "string"
        },
        "trade_feature_matrix": {
          "type": "string"
        },
        "replay_summary": {
          "type": "string"
        },
        "replay_summary_md": {
          "type": "string"
        },
        "manifest": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "completeness": {
      "type": "object",
      "properties": {
        "historical_rows": {
          "type": "integer",
          "minimum": 0
        },
        "partial_rows": {
          "type": "integer",
          "minimum": 0
        },
        "unresolved_rows": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "status": {
      "type": "string"
    },
    "wallet_weighting_requested_mode": {
      "type": "string"
    },
    "wallet_weighting_effective_modes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "replay_score_source": {
      "type": [
        "string",
        "null"
      ]
    },
    "wallet_mode_parity_status": {
      "type": [
        "string",
        "null"
      ]
    },
    "historical_input_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "score_contract_version": {
      "type": [
        "string",
        "null"
      ]
    },
    "signals": {
      "type": "integer",
      "minimum": 0
    },
    "trades": {
      "type": "integer",
      "minimum": 0
    },
    "trade_feature_matrix_rows": {
      "type": "integer",
      "minimum": 0
    },
    "artifact_truth_layer": {
      "type": "string"
    },
    "summary_markdown": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
